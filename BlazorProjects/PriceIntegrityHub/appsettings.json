{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Comparison": {
    "TolerancePercentage": 1.0,
    "CaseInsensitiveMatching": true
  },
  "Scraper": {
    "TargetUrl": "http://books.toscrape.com/",
    "PageLoadDelayMs": 2000,
    "ImplicitWaitSeconds": 10,
    "Headless": true,
    "ProductSelector": "article.product_pod",
    "NameSelector": "h3 a",
    "PriceSelector": "p.price_color",
    "CurrencySymbol": "£"
  },
  "Excel": {
    "WorksheetIndex": 0,
    "HeaderRow": 1,
    "DataStartRow": 2,
    "SkipEmptyRows": true,
    "TrimValues": true,
    "MaxRows": 0,
    "Columns": {
      "ProductName": 1,
      "Price": 2,
      "Status": 0
    }
  },
  "DataStore": {
    "MaxHistoryCount": 100,
    "MaxResultsCount": 10000,
    "MaxProductsCount": 10000,
    "UseUtcTime": true
  }
}
